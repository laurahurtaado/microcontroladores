/*
 * OLED_Text.c
 * Configurado para PIC18F4550 @ 8 MHz
 * Oscilador interno INTOSC (INTOSCIO_EC)
 */

// FOSC = INTOSCIO_EC -> Oscilador interno, RA6/RA7 quedan como I/O
// PLLDIV = 1         -> Sin division (PLL no se usa)
// CPUDIV = OSC1_PLL2 -> CPU = Fosc/1 = 8 MHz
// USBDIV = 1         -> Sin USB
#pragma config PLLDIV = 1, CPUDIV = OSC1_PLL2, USBDIV = 1
#pragma config FOSC = INTOSCIO_EC, FCMEN = OFF, IESO = OFF
#pragma config PWRT = OFF, BOR = OFF, BORV = 3, VREGEN = OFF
#pragma config WDT = OFF
#pragma config WDTPS = 32768
#pragma config CCP2MX = ON, PBADEN = OFF, LPT1OSC = OFF, MCLRE = OFF
#pragma config STVREN = ON, LVP = OFF, ICPRT = OFF, XINST = OFF
#pragma config CP0 = OFF, CP1 = OFF, CP2 = OFF, CP3 = OFF
#pragma config CPB = OFF, CPD = OFF
#pragma config WRT0 = OFF, WRT1 = OFF, WRT2 = OFF, WRT3 = OFF
#pragma config WRTC = OFF, WRTB = OFF, WRTD = OFF
#pragma config EBTR0 = OFF, EBTR1 = OFF, EBTR2 = OFF, EBTR3 = OFF
#pragma config EBTRB = OFF

#define _XTAL_FREQ 8000000      // 8 MHz oscilador interno
#include <xc.h>

#include "i2c.h"                // Libreria del protocolo i2c
#include "ssd1306_oled.h"       // Libreria de la pantalla oled i2c

void main()
{
    // Configurar oscilador interno a 8 MHz
    OSCCON = 0x72;

    ADCON1bits.PCFG = 0x0F;         // Todos los pines como digitales
    I2C_Init_Master(I2C_100KHZ);    
    OLED_Init();                    // Inicializa la pantalla oled

    while(1)
    {
        OLED_SetFont(FONT_1);
        OLED_Write_Text(0, 10, "---LAU---");
        OLED_Update();
        __delay_ms(100);

        OLED_SetFont(FONT_2);
        OLED_Write_Text(0, 20, "---FOMO---");
        OLED_Update();
        __delay_ms(100);

        OLED_SetFont(FONT_2);
        OLED_Write_Text(0, 40, "-TETRANUTRA-");
        OLED_Update();
        __delay_ms(100);

        OLED_Update();
        __delay_ms(100);
    }
}
