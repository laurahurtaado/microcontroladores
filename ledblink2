;=========================================================
; PIC18F4550
; LED en RB0
; 1 segundo ENCENDIDO
; 2 segundos APAGADO
; Oscilador interno
;=========================================================

#include <xc.inc>          ; Librer�a del ensamblador para PIC18

;================ CONFIGURACI�N ==========================
CONFIG  FOSC = INTOSCIO_EC ; Oscilador interno
CONFIG  WDT = OFF          ; Watchdog deshabilitado
CONFIG  LVP = OFF          ; Programaci�n en bajo voltaje OFF
CONFIG  PBADEN = OFF       ; PORTB como digital

;================ VECTOR DE RESET ========================
PSECT resetVec, class=CODE, reloc=2
ORG 0x00                   ; Direcci�n 0 (reset)
GOTO Main                ; Salta al Main del programa

;Variables
PESECT udata
Cont1: DS 1
Cont2: DS 1
Cont3: DS 1

;================ C�DIGO PRINCIPAL =======================
PSECT main_code, class=CODE, reloc=2

Main:
    ;OSCCON - 8Mhz
    MOVLW 0b01110110
    MOVWF OSCCON

    ; Definimos a
    ; RBO:RB3 SALIDAS
    ; RB4:RB7 ENTRADAS
    MOVLW 0xF0
    MOVWF TRISB
    CLRF  LATB

MainLoop:
    BSF     LATB, 0         ; Enciende RB0
    CALL    Delay_200ms
    BCF     LATB, 0         ; Apaga RB0
    CALL    Delay_200ms
    GOTO    MainLoop

; Retardos
Delay_200ms:
    MOVLW   40
    MOVWF   Cont1
D200:
    CALL    Delay_5ms
    DECFSZ  Cont1, F
    GOTO    D200
    RETURN

Delay_5ms:
    MOVLW   250
    MOVWF   Cont2
D5:
    CALL    Delay_20us
    DECFSZ  Cont2, F
    GOTO    D5
    RETURN

Delay_20us:
    MOVLW   25
    MOVWF   Cont3
D20:
    NOP
    NOP
    NOP
    NOP
    DECFSZ  Cont3, F
    GOTO    D20
    RETURN

END
