#include <xc.inc>   ;incluimos definiciones del esamblador para pic18f4550
;confi de bits de configuración (Fuses)
CONFIG  FOSC = INTOSCIO_EC; para usar oscilador interno a 8 Mhz
CONFIG  WDT = OFF;deshabilita el whatchgog timer
CONFIG  LVP = OFF; // la programacion en bajo voltaje
CONFIG  PBADEN = OFF// configura los pines de portB como digitales
;================vectores de inicio=================
PSECT  resetVec, class=CODE, reloc=2
ORG     0x00
GOTO    Inicio
;===========codigo principal======================
PSECT  main_code, class=CODE, reloc=2

Inicio:
    ;===========configurar oscilador interno a 4Mhz=========
    MOVLW   0b01100010
    MOVWF   OSCCON

    CLRF    TRISB
    CLRF    LATB

    ;RA4- BOTON SECUENCIA
    ;RA3- BOTON VELOCIDAD
    MOVLW   0b00011000
    MOVWF   TRISA

    CLRF    SecuenciaActual
    CLRF    VelocidadActual

MainLoop:

    ; ==== Botón cambiar secuencia (RA4)= =====
    BTFSC   PORTA, 4
    CALL    CambiarSecuencia
    ;====== Botón cambiar velocidad (RA3)=======
    BTFSS   PORTA, 3
    CALL    CambiarVelocidad

    MOVF    SecuenciaActual, W
    BNZ     Secuencia1

    CALL    SecuenciaDesplazamiento
    GOTO    MainLoop

Secuencia1:
    DECF    WREG, W
    BNZ     Secuencia2
    CALL    SecuenciaCarrera
    GOTO    MainLoop

Secuencia2:
    DECF    WREG, W
    BNZ     Secuencia3
    CALL    SecuenciaBinario
    GOTO    MainLoop

Secuencia3:
    CALL    SecuenciaAlternancia
    GOTO    MainLoop
;======== cambiar secuencia (igual) ===========
CambiarSecuencia:
    CALL    Retardo_200ms
    BTFS    PORTA, 4
    RETURN

    INCF    SecuenciaActual, F
    MOVLW   4
    SUBWF   SecuenciaActual, W
    BNZ     FinCambio
    CLRF    SecuenciaActual

FinCambio:
    CLRF  LATB 
    CALL Retardo_500ms
    RETURN

;======CAMBIAR VELOCIDAD===============
 CambiarVelocidad:
     CALL  Retardo_200ms
     BTFSC PORTA, 3
     RETURN

     INFC  VelocidActual, F
     MOVLW 3
     SUBWF VelocidaActual, W
     BNZ   FinVel
     CLRF  VelocidadActual

 FinVel:
    RETURN
; =======RETARDO SEGÚN VELOCIDAD=======

RetardoSegunVelocidad:
    MOVF    VelocidadActual,W
    BNZ     Vel1

    CALL    Retardo_1s
    RETURN

Vel1:
    DECF    WREG,W
    BNZ     Vel2
    CALL    Retardo_500ms
    RETURN

Vel2:
    CALL    Retardo_200ms
    RETURN

; ===== secuencia 0 desplazamiento simple =====
SecuenciaDesplazamiento:
    MOVLW   0b00000010   
    MOVWF   LATB
    CALL    RetardoSegunVelocidad ; Solo cambie el retardo para que dependa de la velocidad

    MOVLW   0b00000100
    MOVWF   LATB
    CALL    RetardoSegunVelocidad

    MOVLW   0b00001000
    MOVWF   LATB
    CALL    RetardoSegunVelocidad

    MOVLW   0b00000001
    MOVWF   LATB
    CALL    RetardoSegunVelocidad
    RETURN

SecuenciaCarrera:
    MOVLW   0b00001111
    MOVWF   LATB
    CALL    RetardoSegunVelocidad

    MOVLW   0b00000000
    MOVWF   LATB
    CALL    RetardoSegunVelocidad

    MOVLW   0b00001111
    MOVWF   LATB
    CALL    RetardoSegunVelocidad

    MOVLW   0b00000000
    MOVWF   LATB
    CALL    RetardoSegunVelocidad
    RETURN

; ===== Secuencia 1 carrera de Leds =====
SecuenciaBinario:
    MOVLW   0b00001111
    MOVWF   LATB
    CALL    RetardoSegunVelocidad

    MOVLW   0b00000000
    MOVWF   LATB
    CALL    RetardoSegunVelocidad

    MOVLW   0b00001111   
    MOVWF   LATB
    CALL    RetardoSegunVelocidad

    MOVLW   0b00000000
    MOVWF   LATB
    CALL    RetardoSegunVelocidad
    RETURN

SecuenciaAlternancia:
    MOVLW   0b00000101
    MOVWF   LATB
    CALL    RetardoSegunVelocidad

    MOVLW   0b00001010
    MOVWF   LATB
    CALL    RetardoSegunVelocidad
    RETURN

; ==========
Retardo_1s:
    MOVLW   155  
    MOVWF   ContadorExterno
LoopExterno1s:
    MOVLW   250
    MOVWF   ContadorInterno
LoopInterno1s:
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    DECFSZ  ContadorInterno,F
    GOTO    LoopInterno1s
    DECFSZ  ContadorExterno,F
    GOTO    LoopExterno1s
    RETURN

Retardo_500ms:
    MOVLW   76
    MOVWF   ContadorExterno
LoopExterno500ms:
    MOVLW   250
    MOVWF   ContadorInterno
LoopInterno500ms:
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    DECFSZ  ContadorInterno, F
    GOTO    LoopInterno500ms
    DECFSZ  ContadorExterno, F
    GOTO    LoopExterno500ms
    RETURN

Retardo_200ms:
    MOVLW   50
    MOVWF   ContadorExterno
LoopExterno200ms:
    MOVLW   250
    MOVWF   ContadorInterno
LoopInterno200ms:
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    DECFSZ  ContadorInterno, F
    GOTO    LoopInterno200ms
    DECFSZ  ContadorExterno, F
    GOTO    LoopExterno200ms
    RETURN

PSECT udata
ContadorExterno:   DS 1
ContadorInterno:   DS 1
SecuenciaActual:   DS 1

END
