#include "bme280.h"

//================ ESCRITURA =================
void BME280_Write(uint8_t reg, uint8_t data)
{
    I2C_Start();
    I2C_Write(BME280_ADDR << 1);
    I2C_Write(reg);
    I2C_Write(data);
    I2C_Stop();
}

//================ LECTURA =================
uint8_t BME280_Read(uint8_t reg)
{
    uint8_t data;

    I2C_Start();
    I2C_Write(BME280_ADDR << 1);
    I2C_Write(reg);

    I2C_Restart();
    I2C_Write((BME280_ADDR << 1) | 1);
    data = I2C_Read();
    I2C_Nack();
    I2C_Stop();

    return data;
}

//================ INICIALIZACIÓN =================
void BME280_Init(void)
{
    // Humedad oversampling x1
    BME280_Write(0xF2, 0x01);

    // Temp y presión (aunque no los uses) + modo normal
    BME280_Write(0xF4, 0x27);

    // Configuración standby
    BME280_Write(0xF5, 0xA0);
}

//================ LECTURA RAW HUMEDAD =================
unsigned long BME280_ReadRawHumidity(void)
{
    unsigned long hum = 0;

    uint8_t msb = BME280_Read(0xFD);
    uint8_t lsb = BME280_Read(0xFE);

    hum = ((unsigned long)msb << 8) | lsb;

    return hum;
}

//================ HUMEDAD (%) =================
float BME280_GetHumidity(void)
{
    unsigned long raw = BME280_ReadRawHumidity();

    // Escalado simple (aproximado)
    float humedad = (raw / 65535.0f) * 100.0f;

    return humedad;
}
