#include "max30102.h"
#include "i2c.h"
#include <xc.h>

#define _XTAL_FREQ 8000000

static uint32_t lastBeatTime = 0;

void MAX30102_Write(uint8_t reg, uint8_t value)
{
    I2C_Start();

    I2C_Write(MAX30102_ADDRESS);

    I2C_Write(reg);

    I2C_Write(value);

    I2C_Stop();
}

uint8_t MAX30102_Read(uint8_t reg)
{
    uint8_t data;

    I2C_Start();

    I2C_Write(MAX30102_ADDRESS);

    I2C_Write(reg);

    I2C_Repeated_Start();

    I2C_Write(MAX30102_ADDRESS | 0x01);

    data = I2C_Read(0);

    I2C_Stop();

    return data;
}

void MAX30102_Init(void)
{
    __delay_ms(100);

    MAX30102_Write(0x09, 0x40);

    __delay_ms(100);

    MAX30102_Write(0x09, 0x03);

    MAX30102_Write(0x0A, 0x27);

    MAX30102_Write(0x0C, 0x24);

    MAX30102_Write(0x0D, 0x24);

    MAX30102_Write(0x08, 0x0F);

    MAX30102_Write(0x02, 0x00);

    MAX30102_Write(0x03, 0x00);

    MAX30102_Write(0x04, 0x00);
}

uint32_t MAX30102_ReadIR(void)
{
    uint32_t data;

    I2C_Start();

    I2C_Write(MAX30102_ADDRESS);

    I2C_Write(0x07);

    I2C_Repeated_Start();

    I2C_Write(MAX30102_ADDRESS | 0x01);

    data  = ((uint32_t)I2C_Read(1)) << 16;
    data |= ((uint32_t)I2C_Read(1)) << 8;
    data |= ((uint32_t)I2C_Read(0));

    I2C_Stop();

    data &= 0x03FFFF;

    return data;
}

uint8_t MAX30102_CheckBeat(uint32_t irValue)
{
    static uint32_t threshold = 50000;
    static uint8_t pulseDetected = 0;

    if(irValue > threshold && pulseDetected == 0)
    {
        pulseDetected = 1;
        return 1;
    }

    if(irValue < threshold)
    {
        pulseDetected = 0;
    }

    return 0;
}
