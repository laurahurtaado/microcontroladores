#include <xc.h>
#include <stdio.h>

#define _XTAL_FREQ 8000000

#include "i2c.h"
#include "ssd1306_oled.h"
#include "max30102.h"

#pragma config FOSC = HS
#pragma config WDT = OFF
#pragma config LVP = OFF
#pragma config PBADEN = OFF

char buffer[20];

void main(void)
{
    uint32_t irValue;

    uint16_t bpm = 0;

    uint32_t currentTime = 0;

    uint32_t lastBeat = 0;

    TRISC = 0x00;

    I2C_Master_Init(100000);

    OLED_Init();

    OLED_Clear();

    OLED_YX(0,0);
    OLED_Write_String("MAX30102 TEST");

    MAX30102_Init();

    __delay_ms(1000);

    while(1)
    {
        irValue = MAX30102_ReadIR();

        if(MAX30102_CheckBeat(irValue))
        {
            currentTime++;

            if(lastBeat != 0)
            {
                bpm = 60000 / (currentTime - lastBeat);
            }

            lastBeat = currentTime;
        }

        OLED_Clear();

        OLED_YX(0,0);
        OLED_Write_String("BPM:");

        sprintf(buffer,"%u", bpm);

        OLED_YX(2,0);
        OLED_Write_String(buffer);

        OLED_YX(4,0);
        OLED_Write_String("IR:");

        sprintf(buffer,"%lu", irValue);

        OLED_YX(6,0);
        OLED_Write_String(buffer);

        __delay_ms(50);

        currentTime += 50;
    }
}
