/*
 * MQ-135 + OLED + BUZZER + CONTROL VENTILACION
 * PIC18F4550 @ 8 MHz
 */

#pragma config PLLDIV = 1, CPUDIV = OSC1_PLL2, USBDIV = 1
#pragma config FOSC = INTOSCIO_EC, FCMEN = OFF, IESO = OFF
#pragma config PWRT = OFF, BOR = OFF, BORV = 3, VREGEN = OFF
#pragma config WDT = OFF
#pragma config WDTPS = 32768
#pragma config CCP2MX = ON, PBADEN = OFF, LPT1OSC = OFF, MCLRE = ON
#pragma config STVREN = ON, LVP = OFF, ICPRT = OFF, XINST = OFF

#define _XTAL_FREQ 8000000

#include <xc.h>
#include <stdio.h>

#include "i2c.h"
#include "ssd1306_oled.h"

//================ DEFINICIONES =================
#define MQ_PIN PORTBbits.RB2

#define BUZZER LATCbits.LATC1
#define TRIS_BUZZER TRISCbits.TRISC1

#define FAN LATCbits.LATC0
#define TRIS_FAN TRISCbits.TRISC0

//================ VARIABLES =================
unsigned int contador_mala_calidad = 0;
unsigned char ventilacion_gas = 0;

//================ MAIN =================
void main()
{
    OSCCONbits.IRCF = 0b111;
    OSCCONbits.SCS  = 0b11;
    while(!OSCCONbits.IOFS);

    ADCON1 = 0x0F; // todo digital

    // MQ-135 entrada
    TRISBbits.TRISB2 = 1;

    // Salidas
    TRIS_BUZZER = 0;
    TRIS_FAN = 0;

    BUZZER = 0;
    FAN = 0;

    I2C_Init_Master(I2C_100KHZ);
    OLED_Init();

    char buffer1[20];
    char buffer2[20];

    while(1)
    {
        unsigned char gas = MQ_PIN;

        //============ LÓGICA DE AIRE ============
        if(gas == 1) // AIRE BUENO
        {
            sprintf(buffer1, "Calidad Aire");
            sprintf(buffer2, "BUENA");

            contador_mala_calidad = 0;
            ventilacion_gas = 0;
            BUZZER = 0;
        }
        else // AIRE MALO
        {
            sprintf(buffer1, "Calidad Aire");
            sprintf(buffer2, "MALA");

            ventilacion_gas = 1; // activar ventilación

            contador_mala_calidad++;

            // ? si persiste (ej: ~3 segundos)
            if(contador_mala_calidad > 6)
            {
                BUZZER = 1;
            }
        }

        //============ CONTROL VENTILADOR ============
        // (por ahora solo gas, luego se combina con humedad)
        if(ventilacion_gas)
            FAN = 1;
        else
            FAN = 0;

        //============ OLED ============
        OLED_ClearDisplay();
        OLED_SetFont(FONT_1);
        OLED_Write_Text(0, 0, buffer1);
        OLED_Write_Text(0, 20, buffer2);
        OLED_Update();

        __delay_ms(500);
    }
}
